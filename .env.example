# ============================================
# CONFIGURACIÓN DEL PROYECTO DJANGO
# ============================================
# IMPORTANTE: Copia este archivo a .env y configura tus valores reales
# El archivo .env NUNCA debe subirse a GitHub (está en .gitignore)

# Seguridad
SECRET_KEY=<SET_IN_SERVER_ENV_ONLY>
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
ADMIN_PATH=admin/

# Si usas Nginx/Traefik delante de Django
BEHIND_PROXY=False

# Base de datos
# Para SQLite (desarrollo local):
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ============================================
# PRODUCCIÓN EN VPS CON POSTGRESQL (RECOMENDADO)
# ============================================
# Copia estas variables en tu .env de producción:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=hotel_db
# DB_USER=hotel_user
# DB_PASSWORD=<SET_IN_SERVER_ENV_ONLY>
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_CONN_MAX_AGE=60
# DB_CONN_HEALTH_CHECKS=True
#
# Si usas un servidor DB externo, cambia DB_HOST por la IP/hostname
# y abre el puerto 5432 solo para IPs autorizadas.

# Seguridad HTTPS (producción)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Email (opcional, para envío de confirmaciones)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=<SET_IN_SERVER_ENV_ONLY>

# Configuración hotelera (para futuras mejoras)
HOTEL_NAME=Hostal Rivera
HOTEL_CIF=B12345678
HOTEL_ADDRESS=Calle Principal, 1
HOTEL_CITY=Becerreá
HOTEL_POSTAL_CODE=27640
HOTEL_PHONE=+34 982 360 185
HOTEL_EMAIL=info@hostalrivera.es
