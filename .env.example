# ============================================
# CONFIGURACIÓN DEL PROYECTO DJANGO
# ============================================
# IMPORTANTE: Copia este archivo a .env y configura tus valores reales
# El archivo .env NUNCA debe subirse a GitHub (está en .gitignore)

# Seguridad
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION-use-random-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos
# Para SQLite (desarrollo):
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Para PostgreSQL (producción, descomentar y configurar):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=hotel_db
# DB_USER=hotel_user
# DB_PASSWORD=tu_password_seguro
# DB_HOST=localhost
# DB_PORT=5432

# Email (opcional, para envío de confirmaciones)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-password-app-de-gmail

# Configuración hotelera (para futuras mejoras)
HOTEL_NAME=Hostal Rivera
HOTEL_CIF=B12345678
HOTEL_ADDRESS=Calle Principal, 1
HOTEL_CITY=Becerreá
HOTEL_POSTAL_CODE=27640
HOTEL_PHONE=+34 982 360 185
HOTEL_EMAIL=info@hostalrivera.es
